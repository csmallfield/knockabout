; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Knockabout Prototype"
run/main_scene="res://game.tscn"
config/features=PackedStringArray("4.6")

[autoload]

Tuning="*res://autoload/tuning.gd"
EventBus="*res://autoload/event_bus.gd"
WorldState="*res://autoload/world_state.gd"
Registry="*res://autoload/entity_registry.gd"
ImpactResolver="*res://autoload/impact_resolver.gd"
DebrisPool="*res://autoload/debris_pool.gd"
MapManager="*res://autoload/map_manager.gd"
Dev="*res://autoload/dev.gd"
CombatDirector="*res://autoload/combat_director.gd"
PickupPool="*res://autoload/pickup_pool.gd"
ScoreManager="*res://autoload/score_manager.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

