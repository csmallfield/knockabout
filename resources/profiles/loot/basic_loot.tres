[resource]
script = ExtResource("1")
coin_min = 0
coin_max = 2
drop_chance = 0.35
drops = Array[LootDrop]([SubResource("drop_health"), SubResource("drop_power"), SubResource("drop_speed"), SubResource("drop_invincible")])
